{
  "name": "skillchain",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "skillchain-frontend",
    "skillchain-backend"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names frontend,backend \"npm run dev --prefix skillchain-frontend\" \"npm run dev:watch --prefix skillchain-backend\"",
    "frontend": "npm run dev --prefix skillchain-frontend",
    "backend": "npm run dev --prefix skillchain-backend",
    "build": "npm run build --prefix skillchain-frontend",
    "lint": "npm run lint --prefix skillchain-frontend",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.2.1"
  }
}
