PORT=4000
FRONTEND_URL=http://localhost:3000

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

GITHUB_TOKEN=

# Polygon Amoy examples:
# Free public RPC from current Polygon docs:
BLOCKCHAIN_RPC_URL=https://polygon-amoy.drpc.org
# Optional dedicated/private RPC:
# BLOCKCHAIN_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your-key
# Do not use the deprecated endpoint: https://rpc-amoy.polygon.technology/
BLOCKCHAIN_CHAIN_ID=80002
# Optional. If blank, the backend anchors the hash as a trusted chain record.
BLOCKCHAIN_CONTRACT_ADDRESS=
# Wallet private key used by backend to send anchor transactions.
BLOCKCHAIN_PRIVATE_KEY=
# Public wallet address of the same issuer wallet.
ISSUER_WALLET_ADDRESS=
